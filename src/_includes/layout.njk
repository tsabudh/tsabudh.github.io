<!DOCTYPE html>
<html lang="en">
  <head>
    {% set pageTitle = title or site.title %}
    {% set pageDescription = description or site.description %}
    {% set pageCanonical = canonicalUrl or (site.url ~ page.url) %}
    {% set pageImage = image or site.image %}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}" />
    <meta name="author" content="{{ site.name }}" />
    <link rel="canonical" href="{{ pageCanonical }}" />
    {% if noindex %}
    <meta name="robots" content="noindex, follow" />
    {% else %}
    <meta name="robots" content="index, follow" />
    {% endif %}
    {% if redirectTo %}
    <meta http-equiv="refresh" content="0; url={{ redirectTo }}" />
    {% endif %}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="{{ site.name }}" />
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDescription }}" />
    <meta property="og:url" content="{{ pageCanonical }}" />
    <meta property="og:image" content="{{ pageImage }}" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ pageDescription }}" />
    <meta name="twitter:image" content="{{ pageImage }}" />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": "{{ site.url }}/#sabudh-thapa",
        "name": "Sabudh Thapa",
        "alternateName": "tsabudh",
        "jobTitle": "Software Engineer",
        "description": "{{ site.description }}",
        "url": "{{ site.url }}/",
        "image": "{{ site.image }}",
        "email": "mailto:{{ site.email }}",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Kathmandu",
          "addressCountry": "NP"
        },
        "knowsAbout": [
          "Software Engineering",
          "Distributed Systems",
          "Backend Engineering",
          "Data Infrastructure",
          "PostgreSQL",
          "Kafka",
          "Rust"
        ],
        "sameAs": [
          "https://github.com/tsabudh",
          "https://www.linkedin.com/in/tsabudh",
          "https://medium.com/@tsabudh"
        ]
      }
    </script>
    <link rel="stylesheet" href="/styles/main.css"  type="text/css"/>
    <link rel="stylesheet" href="/styles/compiled.css"  type="text/css"/>
    <link rel="stylesheet" href="/styles/tailwind.css"  type="text/css"/>
    {% if site.googleAnalyticsMeasurementId %}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.googleAnalyticsMeasurementId }}"></script>
    <script>
      window.__PORTFOLIO_GA_MEASUREMENT_ID__ = "{{ site.googleAnalyticsMeasurementId }}";
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", "{{ site.googleAnalyticsMeasurementId }}", { send_page_view: false });
    </script>
    {% else %}
    <script>
      window.__PORTFOLIO_GA_MEASUREMENT_ID__ = "";
    </script>
    {% endif %}
    <script type="module" src="/scripts/barba.js"></script>
  </head>
  <body class="text-slate-950">
    <div class="barba-load-container bg-slate-700">
      <div
        class="loading-screen relative h-full w-full flex items-center justify-center overflow-hidden"
      >
        <div
          class="barba-load-container_bg-texts absolute inset-0 text-slate-600 text-9xl opacity-45 rotate-12 scale-150 whitespace-nowrap space-y-9 font-lexend font-bold"
        >
          <p>
            <span> SYSTEMS THAT KEEP WORK MOVING </span>
            <span> SYSTEMS THAT KEEP WORK MOVING </span>
          </p>
          <p>
            <span> DATA THAT STAYS CORRECT UNDER FAILURE </span>
            <span> DATA THAT STAYS CORRECT UNDER FAILURE </span>
          </p>
          <p>
            <span> IDEMPOTENT JOBS THAT RETRY SAFELY </span>
            <span> IDEMPOTENT JOBS THAT RETRY SAFELY </span>
          </p>
          <p>
            <span> QUERIES SHAPED FOR THE DATA THEY READ </span>
            <span> QUERIES SHAPED FOR THE DATA THEY READ </span>
          </p>
          <p>
            <span> POINT-IN-TIME RECOVERY BEFORE INCIDENTS </span>
            <span> POINT-IN-TIME RECOVERY BEFORE INCIDENTS </span>
          </p>
          <p>
            <span> DISTRIBUTED TRACING AT SERVICE BOUNDARIES </span>
            <span> DISTRIBUTED TRACING AT SERVICE BOUNDARIES </span>
          </p>
        </div>
        <h1
          id="loading-screen-text"
          class="font-delight text-9xl text-white z-50"
        >
          Loading
        </h1>
      </div>
    </div>
    <div id="smooth-wrapper">
      <div id="smooth-content" class="">
        <div data-barba="wrapper">
          <div data-barba="container" data-barba-namespace="{{ namespace }}">
            {{ content | safe }}
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
