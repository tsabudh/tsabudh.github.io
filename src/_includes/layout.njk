<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/styles/main.css"  type="text/css"/>
    <link rel="stylesheet" href="/styles/compiled.css"  type="text/css"/>
    <link rel="stylesheet" href="/styles/tailwind.css"  type="text/css"/>
    {% if site.googleAnalyticsMeasurementId %}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.googleAnalyticsMeasurementId }}"></script>
    <script>
      window.__PORTFOLIO_GA_MEASUREMENT_ID__ = "{{ site.googleAnalyticsMeasurementId }}";
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", "{{ site.googleAnalyticsMeasurementId }}", { send_page_view: false });
    </script>
    {% else %}
    <script>
      window.__PORTFOLIO_GA_MEASUREMENT_ID__ = "";
    </script>
    {% endif %}
    <script type="module" src="/scripts/barba.js"></script>
  </head>
  <body class="text-slate-950">
    <div class="barba-load-container bg-slate-700">
      <div
        class="loading-screen relative h-full w-full flex items-center justify-center overflow-hidden"
      >
        <div
          class="barba-load-container_bg-texts absolute inset-0 text-slate-600 text-9xl opacity-45 rotate-12 scale-150 whitespace-nowrap space-y-9 font-lexend font-bold"
        >
          <p>
            <span> SYSTEMS THAT KEEP WORK MOVING </span>
            <span> SYSTEMS THAT KEEP WORK MOVING </span>
          </p>
          <p>
            <span> DATA THAT STAYS CORRECT UNDER FAILURE </span>
            <span> DATA THAT STAYS CORRECT UNDER FAILURE </span>
          </p>
          <p>
            <span> IDEMPOTENT JOBS THAT RETRY SAFELY </span>
            <span> IDEMPOTENT JOBS THAT RETRY SAFELY </span>
          </p>
          <p>
            <span> QUERIES SHAPED FOR THE DATA THEY READ </span>
            <span> QUERIES SHAPED FOR THE DATA THEY READ </span>
          </p>
          <p>
            <span> POINT-IN-TIME RECOVERY BEFORE INCIDENTS </span>
            <span> POINT-IN-TIME RECOVERY BEFORE INCIDENTS </span>
          </p>
          <p>
            <span> DISTRIBUTED TRACING AT SERVICE BOUNDARIES </span>
            <span> DISTRIBUTED TRACING AT SERVICE BOUNDARIES </span>
          </p>
        </div>
        <h1
          id="loading-screen-text"
          class="font-delight text-9xl text-white z-50"
        >
          Loading
        </h1>
      </div>
    </div>
    <div id="smooth-wrapper">
      <div id="smooth-content" class="">
        <div data-barba="wrapper">
          <div data-barba="container" data-barba-namespace="{{ namespace }}">
            {{ content | safe }}
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
